<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 250" width="180" height="250">
  <defs>
    <linearGradient id="hybridGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f97316;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#dc2626;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#991b1b;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="180" height="250" fill="url(#hybridGrad)"/>
  <rect width="180" height="40" fill="rgba(0,0,0,0.3)"/>
  <text x="90" y="20" text-anchor="middle" fill="white" font-size="10" font-weight="bold">ГИБРИДНАЯ</text>
  <text x="90" y="35" text-anchor="middle" fill="white" font-size="9">Зверь-Демон</text>
  <circle cx="90" cy="120" r="40" fill="rgba(255,255,255,0.2)"/>
  <text x="90" y="130" text-anchor="middle" fill="white" font-size="24" font-weight="bold">🔀</text>
  <text x="90" y="210" text-anchor="middle" fill="white" font-size="11" font-weight="bold">Химера</text>
  <text x="15" y="235" fill="white" font-size="9">АТК: 4</text>
  <text x="90" y="235" text-anchor="middle" fill="white" font-size="9">ХР: 4</text>
  <text x="165" y="235" text-anchor="end" fill="white" font-size="9">МР: 3</text>
</svg>